{
  "_meta": {
    "name": "Population Density: 4-State Bars",
    "description": "Census tracts in CA, TX, NY, FL extruded by population density and colored by median household income.",
    "theme": "When the Land Speaks",
    "snapshot_date": "2024-12-01"
  },
  "name": "Population Density: 4-State Bars",
  "description": "Census tracts in CA, TX, NY, FL extruded by population density and colored by median household income.",
  "center_lng": -97.0,
  "center_lat": 37.0,
  "zoom": 4.0,
  "bearing": 0.0,
  "pitch": 50.0,
  "basemap_style": "dark-matter",
  "show_basemap_labels": false,
  "visibility": "public",
  "widgets": ["legend", "measurement"],
  "layers": [
    {
      "_stem": "pop_density_tracts",
      "_ext": ".geojson",
      "display_name": "Density (extruded) by Income (color)",
      "sort_order": 0,
      "visible": true,
      "opacity": 0.85,
      "paint": {
        "fill-color": [
          "interpolate",
          ["linear"],
          ["coalesce", ["to-number", ["get", "_mhi"]], 0],
          30000, "#440154",
          60000, "#3b528b",
          90000, "#21908c",
          120000, "#5dc863",
          150000, "#fde725"
        ],
        "fill-opacity": 0.85,
        "_outline-color": "#1a1a2e",
        "_outline-width": 0.1,
        "_height_column": "_density"
      },
      "layout": {},
      "layer_type": "vector_geolens",
      "filter": [
        "all",
        ["has", "_mhi"],
        [">", ["coalesce", ["to-number", ["get", "_mhi"]], 0], 0]
      ],
      "label_config": null,
      "style_config": {
        "mode": "graduated",
        "column": "_mhi",
        "target": "color",
        "classCount": 5,
        "method": "manual",
        "ramp": "Viridis",
        "colors": ["#440154", "#3b528b", "#21908c", "#5dc863", "#fde725"],
        "breaks": [60000, 90000, 120000, 150000]
      },
      "show_in_legend": true
    }
  ]
}
