          80000, "#00b8a9",
          115000, "#ffbf3f",
          160000, "#ff4d6d"
        ],
        "fill-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          11,
          0.42,
          13,
          0.68,
          15,
          0.9
        ],
        "fill-outline-color": "rgba(0,0,0,0)"
      },
      "layout": {},
      "layer_type": "vector_geolens",
      "filter": [
        "all",
        ["has", "_mhi"],
        [">", ["coalesce", ["to-number", ["get", "_mhi"]], 0], 0],
        [">", ["coalesce", ["to-number", ["get", "_density"]], 0], 0]
      ],
      "label_config": null,
      "style_config": {
        "mode": "graduated",
        "column": "_mhi",
        "target": "color",
        "classCount": 5,
        "method": "manual",
        "ramp": "Custom",
        "colors": ["#2b1a6b", "#135dd8", "#00b8a9", "#ffbf3f", "#ff4d6d"],
        "breaks": [50000, 80000, 115000, 160000],
        "builder": {
          "heightColumn": "_density",
          "heightScale": 0.035,
          "extrusionMinZoom": 12.8,
          "extrusionOpacity": 0.92,
          "outlineColor": "#08121d",
          "outlineWidth": 0.18
        }
      },
      "show_in_legend": true
