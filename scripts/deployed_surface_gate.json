    {
      "id": "marketing_home",
      "url": "https://getgeolens.com/",
      "required": [
        {
          "id": "curl_installer",
          "pattern": "curl\\s+-fsSL\\s+https://getgeolens\\.com/install\\.sh\\s+\\|\\s+sh",
          "flags": "i",
          "reason": "Marketing home should show the public installer command."
        },
        {
          "id": "ogc_api_collections_url",
          "pattern": "http://localhost:8080/api/collections",
          "flags": "i",
          "reason": "Marketing home should route OGC examples through the frontend /api path."
        }
      ],
      "forbidden": [
        {
          "id": "stale_geolens_yml",
          "pattern": "\\bgeolens\\.yml\\b",
          "flags": "i",
          "reason": "GeoLens ships docker-compose.yml and docker-compose.prod.yml."
        },
        {
          "id": "raw_ogc_collections_url",
          "pattern": "localhost:8001/collections",
          "flags": "i",
          "reason": "Public OGC examples should use http://localhost:8080/api/collections."
        },
        {
          "id": "ogc_compliant_claim",
          "pattern": "\\bOGC[- ]API[- ](?:Compliant|compliance)\\b|\\bOGC[- ](?:Compliant|compliance)\\b",
          "flags": "i",
          "reason": "Public copy should claim OGC API support, not certification or compliance status."
        }
      ]
    },
