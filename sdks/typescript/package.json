{
  "name": "@geolens/sdk",
  "version": "1.0.1",
  "description": "Auto-generated TypeScript SDK for the GeoLens API. Typed clients with Bearer + API-key auth helpers.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/geolens-io/geolens",
  "repository": {
    "type": "git",
    "url": "https://github.com/geolens-io/geolens.git",
    "directory": "sdks/typescript"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate": "openapi-ts",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@hey-api/client-fetch": "0.13.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.96.1",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "geolens",
    "geospatial",
    "openapi",
    "sdk",
    "typescript"
  ]
}
