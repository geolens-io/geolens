{
  "name": "@geolens/sdk",
  "version": "1.4.4",
  "description": "Auto-generated TypeScript SDK for the GeoLens API. Typed clients with Bearer + API-key auth helpers.",
  "license": "Apache-2.0",
  "author": "Carto Concepts, LLC",
  "homepage": "https://github.com/geolens-io/geolens",
  "repository": {
    "type": "git",
    "url": "https://github.com/geolens-io/geolens.git",
    "directory": "sdks/typescript"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "generate": "openapi-ts",
    "build": "tsc && node scripts/fix-esm-extensions.mjs",
    "verify:esm": "node -e \"import('./dist/index.js').then(m => { if (typeof m.createGeolensClient !== 'function') throw new Error('createGeolensClient export missing'); console.log('esm import ok'); })\"",
    "test": "node --test test/auth_stale_headers.test.mjs test/prototype_substitution.test.mjs",
    "prepublishOnly": "npm run build && npm run verify:esm"
  },
  "dependencies": {
    "@hey-api/client-fetch": "0.13.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.99.0",
    "typescript": "5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "geolens",
    "geospatial",
    "openapi",
    "sdk",
    "typescript"
  ]
}
