{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"],
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true

    /*
     * fix(#438): ARC-09 — `noUncheckedIndexedAccess` is deliberately OFF.
     * A sizing trial (2026-07-10) produced 554 errors across ~100 files,
     * concentrated in map-styling / style-spec code (VrtCreatorForm 33,
     * SpatialFilterPanel 26, classification 25, plus builder tests). Enabling
     * it is its own migration, best done alongside the ARC-01 typed adapter
     * seam that also removes the ARC-11 `as unknown as` cluster. Same call for
     * exactOptionalPropertyTypes / noImplicitReturns / noImplicitOverride.
     */
  },
  "include": ["src"]
}
