[Unit]
Description=GeoLens Docker Compose Stack
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/geolens
ExecStart=/usr/bin/docker compose -f docker-compose.prod.yml up -d --wait --wait-timeout 120
ExecStop=/usr/bin/docker compose -f docker-compose.prod.yml down

[Install]
WantedBy=multi-user.target
