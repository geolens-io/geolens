# ==============================================================================
# GeoLens Demo Environment — TEMPLATE
#
# DO NOT use this file directly. Instead:
#   ./scripts/init-demo-env.sh        # generates .env.demo with random per-deploy credentials
#
# Then start the stack:
#   docker compose -f docker-compose.yml -f docker-compose.demo.yml --env-file .env.demo up -d
#
# Phase 1061 SEC-S06: the previous .env.demo committed real credentials that were
# world-known by anyone with read access to this repository. The credentials are
# now generated per-deploy. The backend's validate_demo_credentials_guard refuses
# to boot if the committed-template values land in .env.demo even with
# GEOLENS_DEMO_MODE=true — you must run init-demo-env.sh first.
# ==============================================================================

# --- Database ---
POSTGRES_DB=geolens
POSTGRES_USER=geolens
POSTGRES_PASSWORD=REPLACE_ME_WITH_init-demo-env.sh

# --- Authentication ---
JWT_SECRET_KEY=REPLACE_ME_WITH_init-demo-env.sh
GEOLENS_ADMIN_USERNAME=admin
GEOLENS_ADMIN_PASSWORD=REPLACE_ME_WITH_init-demo-env.sh

GEOLENS_DEMO_MODE=true

# --- MinIO (cloud-dev profile only) ---
MINIO_ROOT_USER=REPLACE_ME_WITH_init-demo-env.sh
MINIO_ROOT_PASSWORD=REPLACE_ME_WITH_init-demo-env.sh

# --- Public URLs (change to your demo domain) ---
# PUBLIC_APP_URL=https://demo.getgeolens.com
# PUBLIC_API_URL=https://demo.getgeolens.com/api

# --- Logging ---
LOG_JSON=true
LOG_LEVEL=INFO

# --- Upload (reduced for demo safety) ---
UPLOAD_MAX_SIZE_MB=50

# --- Host Ports ---
DB_PORT=5432
API_PORT=8000
FRONTEND_PORT=8080

# --- Demo Reset ---
RESET_INTERVAL_HOURS=24
