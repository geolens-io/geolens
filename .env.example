# ==============================================================================
# GeoLens Environment Configuration
# ==============================================================================
# Copy this file to .env, or run `bash scripts/install.sh` which handles the
# [REQUIRED] vars for you and prompts for admin credentials.
# For production, change every value marked [CHANGE IN PRODUCTION].
#
# Each var carries its own [REQUIRED] / [OPTIONAL] / [CHANGE IN PRODUCTION]
# tag in the comment above it. This index groups the sections so you can skip
# to what you need without relying on a count that drifts as features are added:
#
#   [REQUIRED] first-standup must edit (install.sh handles these for you):
#     Database, Authentication
#
#   [COMMON] often touched (port collisions, public URLs, optional features):
#     Public URLs, Application Experience, Logging, Upload, Host Ports,
#     CORS, Backup Automation, Notifications, LLM Inference, Semantic Search & Embeddings,
#     Storage Provider, MinIO/Local S3 (cloud-dev profile), Cache Provider
#
#   [ADVANCED] rarely touched — production tuning, opt-out the defaults:
#     Edition/Licensing/Tenancy, Container Resource Limits,
#     Uvicorn Tuning, Configuration Lockdown, CDN, Tile Cache, Worker,
#     Frontend Dev-Server Proxy, Tooling/Load Tests, Managed Database,
#     External Connection Pooler, Connection Pool Tuning, Rate Limits
#
# Sections below are demarcated with `# --- <Name> ---` lines. A
# `# ===== ADVANCED / PRODUCTION-TUNING BELOW =====` divider marks where
# the trailing run of production-tuning sections begins.
# ==============================================================================

# --- Database ---
# PostgreSQL database name
# Type: string | Default: geolens
POSTGRES_DB=geolens

# PostgreSQL username
# Type: string | Default: geolens
POSTGRES_USER=geolens

# [CHANGE IN PRODUCTION] PostgreSQL password
# Type: string | Default: geolens (local dev)
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=geolens

# --- Authentication ---
# [REQUIRED] Secret key for signing JWT tokens (must be at least 32 chars)
# Type: string | No default — the application refuses to start until this is set
# Generate with: openssl rand -hex 32
# NOTE: known-public example values like "dev-only-change-me-in-production"
# are rejected at startup. Generate a real secret.
JWT_SECRET_KEY=

# JWT signing algorithm
# Type: string | Default: HS256 | Options: HS256
# JWT_ALGORITHM=HS256

# JWT access token lifetime in minutes
# Type: integer (minimum 1) | Default: 15
# ACCESS_TOKEN_EXPIRE_MINUTES=15

# JWT refresh token lifetime in days
# Type: integer (minimum 1) | Default: 7
# REFRESH_TOKEN_EXPIRE_DAYS=7

# Password complexity. Enforced at every password entry
# point (register, change-password, admin create).
# Defaults shown — uncomment to override.

# Minimum password length in characters.
# Type: integer (minimum 8) | Default: 12
# PASSWORD_MIN_LENGTH=12

# Number of character classes required (out of 4: lowercase, uppercase, digit, symbol).
# Type: integer (1-4) | Default: 3
# PASSWORD_REQUIRE_CLASSES=3

# [REQUIRED] Admin account username — created on first startup when no users exist
# Type: string | No default — the application refuses to start until this is set
# Pick any non-empty username (e.g., admin, ops, ishiland).
# NOTE: empty values fail boot per the same pattern as JWT_SECRET_KEY.
GEOLENS_ADMIN_USERNAME=

# [REQUIRED] Admin account password — created on first startup when no users exist
# Type: string | No default — the application refuses to start until this is set
# Min length: 8. Generate a strong one: openssl rand -base64 16
# NOTE: empty values fail boot, the same as the other required secrets.
GEOLENS_ADMIN_PASSWORD=

# Note: POSTGRES_HOST / POSTGRES_PORT are set automatically by docker-compose.yml
# (host=db, port=5432). When running the backend test suite outside Docker, copy
# .env.test.example to .env.test instead — see backend/tests/conftest.py for the
# variables required by the host-side test path (POSTGRES_HOST=localhost, etc.).

# Whether new user self-registration is enabled. Default is false for safe
# self-hosted installs. If enabled with SMTP email verification, registration
# email delivery is uniform for new and colliding submissions.
# Type: boolean | Default: false
# REGISTRATION_ENABLED=false

# PostgreSQL schema name for the Procrastinate job queue tables
# Type: string | Default: catalog
# PROCRASTINATE_SCHEMA=catalog

# --- Application Experience ---
# Show the login page at the root URL for anonymous visitors. When false, the
# public catalog remains the landing surface.
# Type: boolean | Default: false
# LANDING_FIRST=false

# Display the persistent demo-account banner to authenticated users.
# Type: boolean | Default: false
# DEMO_MODE=false

# --- Public URLs ---
# [OPTIONAL] Browser-facing app URL (used for share links, OAuth redirects).
# Built-in default: http://localhost:8080 (matches _DEFAULT_PUBLIC_APP_URL in
# backend/app/core/public_urls.py).
# Type: string | Default: http://localhost:8080
# PUBLIC_APP_URL=http://localhost:8080

# [OPTIONAL] Externally-reachable API base URL (used in OGC self/collection/next
# link hrefs and similar self-referencing URL emissions). Built-in default:
# http://localhost:8000 (matches _DEFAULT_PUBLIC_API_URL in
# backend/app/core/public_urls.py). Containerized dev typically sets this to
# http://localhost:8080/api so the Vite dev-proxy rewrites it to the API
# container — see frontend/vite.config.ts.
# Type: string | Default: http://localhost:8000
# PUBLIC_API_URL=http://localhost:8000

# Public, monitored organization mailbox used as the DCAT-US 3.0 contactPoint
# when a published dataset has no usable record-level contact. DCAT-US exports
# with unresolved mandatory contact metadata return 503 rather than silently
# disappearing from the catalog feed. Use a role mailbox, not a person's email.
# Type: email | Default: unset
# DCAT_CONTACT_EMAIL=metadata@example.gov

# [DEPRECATED] Legacy alias for PUBLIC_API_URL. Use PUBLIC_API_URL instead.
# When set, the application logs a deprecation warning at startup and still
# resolves to PUBLIC_API_URL for backward compatibility. Removal is deferred
# to a future major release: public_base_url is also a backward-compat field
# in the public TileConfig API response, so dropping it is a breaking API/SDK
# change to coordinate with the SDKs and frontend.
# Type: string | Default: none
# PUBLIC_BASE_URL=

# --- Deployment environment ---
# Controls security-sensitive behavior: API docs exposure (/docs, /redoc) and
# the Secure flag on the OAuth session cookie.
#   development -> docs enabled, session cookie WITHOUT Secure (safe for HTTP)
#   production  -> docs disabled, session cookie WITH Secure (HTTPS only)
# Set this to "production" on every public-facing, TLS-terminated deployment.
# If unset, the app falls back to using LOG_JSON as the production indicator
# (backward compatibility with deployments configured before this setting).
# Type: string | Default: (unset -> LOG_JSON fallback) | Options: development, production
# ENVIRONMENT=production

# --- Edition, Licensing & Tenancy ---
# [OPTIONAL] Explicit edition request. Leave unset to use the default community
# behavior or extension auto-detection. The non-community value requires a
# pre-baked extension overlay; backend and migration boot guards fail closed
# when it is requested without one.
# Type: string | Default: unset | Options: community, enterprise
# GEOLENS_EDITION=

# Deployment tenancy posture. multi_tenant requires an overlay that provides
# the tenant isolation layer; community/self-hosted deployments use single_tenant.
# Type: string | Default: single_tenant | Options: single_tenant, multi_tenant
# GEOLENS_TENANCY_MODE=single_tenant

# Force community mode unless a valid signed license is present.
# Type: boolean | Default: false
# GEOLENS_LICENSE_ENFORCE=false

# Signed license token. Prefer this inline input for Compose.
# Keep empty for the Apache-2.0 community edition.
# Type: secret string | No default
# GEOLENS_LICENSE_KEY=

# Alternative path to a signed license token inside the backend containers.
# A custom Compose override must mount this path read-only into migrate, api,
# and worker. GEOLENS_LICENSE_KEY takes precedence when both are set.
# Type: absolute container path | No default
# GEOLENS_LICENSE_FILE=

# Optional audience/deployment identifier required by audience-bound licenses.
# Type: string | No default
# GEOLENS_LICENSE_AUDIENCE=

# --- Logging ---
# Output logs in JSON format (recommended for production log aggregation).
# NOTE: this controls LOG FORMAT ONLY. It no longer governs security posture
# (docs exposure / session cookie Secure flag) — use ENVIRONMENT for that. For
# backward compatibility, if ENVIRONMENT is unset, LOG_JSON=true still implies
# the production security posture.
# Type: boolean | Default: false
# LOG_JSON=false

# Log level
# Type: string | Default: INFO | Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# --- Upload ---
# Maximum upload file size in megabytes
# Type: integer (minimum 1) | Default: 500
# UPLOAD_MAX_SIZE_MB=500

# Staging directory for uploaded files.
# GAP-022: this is NOT an operator knob in the Docker deployment. The api,
# worker, and titiler containers SHARE one named volume (`upload_staging`)
# mounted at the FIXED path /app/staging; all three must see the same files at
# the same absolute path or fan-out ingest and raster tiling break. Compose
# pins UPLOAD_STAGING_DIR=/app/staging on every service, so overriding it here
# would desync the app's path from the (unchanged) mount target. Only override
# this for a bare-metal/non-compose run where you control every process's
# working tree. Type: string | Default: /app/staging

# Allowed file extensions for upload (comma-separated)
# Type: string | Default: .zip,.gpkg,.geojson,.json,.csv,.tif,.tiff,.xlsx,.xls
# UPLOAD_ALLOWED_EXTENSIONS=.zip,.gpkg,.geojson,.json,.csv,.tif,.tiff,.xlsx,.xls

# [OPTIONAL] GDAL_HTTP_TIMEOUT (seconds) passed to ogr2ogr during ingest.
# Raised from the 120s hardcoded default that timed out 50% of AGO
# layers. Raise further for very large remote-fetched datasets; lower for
# fail-fast feedback during ingest debugging.
# Type: integer (minimum 1) | Default: 300
# INGEST_HTTP_TIMEOUT_SECONDS=300

# --- Uvicorn Tuning ---
# Number of uvicorn worker processes. Dev compose default 1 (compatible with
# --reload). Production deploy: 2-4 depending on CPU.
# Multiplies request concurrency but also process memory (~150M baseline per worker).
# Type: integer | Default: 1
# UVICORN_WORKERS=1

# Keep-alive timeout in seconds — how long a connection stays open between requests.
# Default 5s matches uvicorn upstream; tune up for clients with chatty long-poll patterns.
# Type: integer | Default: 5
# UVICORN_TIMEOUT_KEEP_ALIVE=5

# Graceful-shutdown timeout in seconds — max time uvicorn waits for in-flight
# requests to finish before SIGKILL. 30s default covers slow GDAL ingest finalize.
# Type: integer | Default: 30
# UVICORN_TIMEOUT_GRACEFUL_SHUTDOWN=30

# --- Configuration Lockdown ---
# [OPTIONAL] When true, all admin-overridable settings are locked to their
# environment values. The PersistentConfig DB layer is bypassed for reads and
# returns 403 on writes. Use for hardened production deployments where operators
# must commit changes via env vars (and a re-deploy) instead of the admin UI.
# The admin Settings UI displays a banner indicating lockdown is active.
# Type: boolean | Default: false | Accepted: true, 1, yes
# ENV_ONLY_CONFIG=false

# --- Host Ports (development only) ---
# These are only used by docker-compose.yml for local development. They map host
# ports to the container ports — change them if 5434/8001/8080 are already taken.

# Host port for the Postgres container (container port is always 5432)
# Type: integer | Default: 5434
DB_PORT=5434

# Host port for the API container (container port is always 8000)
# Type: integer | Default: 8001
API_PORT=8001

# Host port for the frontend container (container port is always 5173)
# Type: integer | Default: 8080
FRONTEND_PORT=8080

# --- Container Resource Limits ---
# Docker memory limits accept a number plus unit (for example 512m, 2g).
# Tune these together so their sum fits the host with operating-system headroom.
#
# PostgreSQL memory cap.
# Type: Docker byte value | Default: 2g
# DB_MEM_LIMIT=2g
#
# FastAPI memory cap.
# Type: Docker byte value | Default: 2g
# API_MEM_LIMIT=2g
#
# GDAL/ingest worker memory cap.
# Type: Docker byte value | Default: 4g
# WORKER_MEM_LIMIT=4g
#
# Titiler raster renderer memory cap.
# Type: Docker byte value | Default: 1g
# TITILER_MEM_LIMIT=1g
#
# Production nginx frontend memory cap.
# Type: Docker byte value | Default: 128m
# FRONTEND_MEM_LIMIT=128m
#
# Backup container memory cap.
# Type: Docker byte value | Default: 512m
# BACKUP_MEM_LIMIT=512m

# --- CORS ---
# [OPTIONAL] Comma-separated list of allowed origins for cross-origin API requests
# Leave empty for same-origin only (no CORS headers sent).
# Required when the frontend is served from a different domain than the API.
# Type: string (comma-separated URLs) | Default: "" (same-origin only)
# Example: https://app.example.com,https://other.example.com
# CORS_ALLOWED_ORIGINS=

# --- Backup Automation ---
# Cron schedule for automated database backups (cron expression)
# Default runs daily at 2:00 AM UTC
# Type: string (cron expression) | Default: 0 2 * * *
# BACKUP_SCHEDULE=0 2 * * *

# Number of daily backups to retain locally
# Type: integer | Default: 7
# BACKUP_RETENTION_DAILY=7

# Number of weekly (Sunday) backups to retain locally
# Type: integer | Default: 4
# BACKUP_RETENTION_WEEKLY=4

# Enable off-site backup upload to S3-compatible storage
# Uses the same S3_* credentials configured in Infrastructure Providers section.
# Type: boolean | Default: false
# BACKUP_S3_ENABLED=false

# --- Notifications ---
# Outbound notifications are disabled unless this master switch is true and at
# least one channel below is configured.
# Type: boolean | Default: false
# NOTIFICATIONS_ENABLED=false

# SMTP server configuration. SMTP_PASSWORD is optional for relays that support
# trusted-network delivery; otherwise obtain it from the mail provider.
# Type: hostname | No default
# SMTP_HOST=
# Type: integer (1-65535) | Default: 587
# SMTP_PORT=587
# Type: string | No default
# SMTP_USERNAME=
# Type: secret string | No default
# SMTP_PASSWORD=
# Type: email address | No default
# SMTP_FROM_ADDRESS=
# Type: boolean | Default: true
# SMTP_USE_TLS=true

# Generic incoming-webhook endpoint and optional HMAC signing secret.
# Type: URL | No default
# NOTIFICATION_WEBHOOK_URL=
# Type: secret string | No default
# NOTIFICATION_WEBHOOK_SECRET=

# Per-event opt-ins. The master switch above must also be true.
# Type: boolean | Default: false
# NOTIFY_ON_SIGNUP=false
# Type: boolean | Default: false
# NOTIFY_ON_INGEST_COMPLETE=false
# Type: boolean | Default: false
# NOTIFY_ON_INGEST_FAILED=false
# Type: boolean | Default: false
# NOTIFY_ON_HEALTH_ALERT=false

# Recipient for event notifications; defaults to SMTP_FROM_ADDRESS when unset.
# Type: email address | No default
# NOTIFICATION_ADMIN_EMAIL=

# ==============================================================================
# AI & Embeddings
# All settings below are optional. AI features are disabled when no API key is set.
# All AI settings can also be overridden from Admin > Settings > AI.
# ==============================================================================

# --- LLM Inference ---
# [OPTIONAL] Anthropic API key for Claude models
# Type: string | No default
# ANTHROPIC_API_KEY=

# [OPTIONAL] OpenAI API key (used for OpenAI-compatible providers)
# Type: string | No default
# OPENAI_API_KEY=

# [OPTIONAL] LLM model for Anthropic provider
# Type: string | Default: claude-sonnet-5
# LLM_MODEL=claude-sonnet-5

# [OPTIONAL] LLM model for OpenAI-compatible provider
# Type: string | Default: gpt-4o
# OPENAI_MODEL=gpt-4o

# [OPTIONAL] Lighter LLM model for SQL generation (Ask AI "query_data") + AI metadata.
# Type: string | Default: reuses OPENAI_MODEL (Anthropic provider uses claude-haiku)
# Must be a model your provider actually serves; for Azure OpenAI it must match a
# deployment name. Leave blank to reuse OPENAI_MODEL (recommended).
# OPENAI_MODEL_LIGHT=

# [OPTIONAL] Custom base URL for OpenAI-compatible providers (Ollama, Groq, Together, etc.)
# Type: string | No default
# Example: http://host.docker.internal:11434/v1 (Ollama)
# OPENAI_BASE_URL=

# --- Semantic Search & Embeddings ---
# [OPTIONAL] Embedding model name (must be available at the embedding endpoint)
# Type: string | Default: text-embedding-3-small
# EMBEDDING_MODEL=text-embedding-3-small

# [OPTIONAL] Vector dimensions output by the embedding model
# Type: integer (1-4096) | Default: 1536
# EMBEDDING_DIMS=1536

# [OPTIONAL] Separate base URL for embedding generation
# Falls back to OPENAI_BASE_URL if empty.
# Type: string | No default
# EMBEDDING_BASE_URL=

# ==============================================================================
# Infrastructure Providers (v5.0 Cloud-Ready)
# All settings below are optional. Defaults work with Docker Compose.
# ==============================================================================

# --- Storage Provider ---
# [OPTIONAL] Storage backend for uploaded files
# Type: string | Default: local | Options: local, s3, azure
# STORAGE_PROVIDER=local

# [OPTIONAL] S3-compatible endpoint URL (required when STORAGE_PROVIDER=s3)
# For AWS S3: leave unset (uses default). For MinIO: http://minio:9000
# Type: string | No default
# S3_ENDPOINT=

# [OPTIONAL] S3 bucket name (required when STORAGE_PROVIDER=s3)
# Type: string | No default
# S3_BUCKET=

# [OPTIONAL] S3 access key ID (required when STORAGE_PROVIDER=s3)
# Type: string | No default
# S3_ACCESS_KEY_ID=

# [OPTIONAL] S3 secret access key (required when STORAGE_PROVIDER=s3)
# Type: string | No default
# S3_SECRET_ACCESS_KEY=

# [OPTIONAL] S3 region
# Type: string | Default: us-east-1
# S3_REGION=us-east-1

# [OPTIONAL] Allow HTTP (non-TLS) connections to S3 endpoint (for local MinIO)
# Type: boolean | Default: false
# S3_ALLOW_HTTP=false

# [OPTIONAL] S3 addressing style: auto, path, or virtual
# Use 'path' for MinIO; 'virtual' for native AWS S3 in some regions; 'auto' lets the SDK decide.
# Type: string | Default: auto | Options: auto, path, virtual
# S3_ADDRESSING_STYLE=auto

# --- MinIO (cloud-dev profile only) ---
# REQUIRED if you run `docker compose --profile cloud-dev up`.
# No defaults — boot fails fast if these are unset (legacy MinIO defaults removed).
# Generate with `openssl rand -base64 24`. Keep in sync with
# S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY below when using local MinIO.
# Uncomment + set ONLY if you intend to run --profile cloud-dev — they ship
# commented out so the default-profile install path doesn't carry empty
# placeholders into the live .env.
# MINIO_ROOT_USER=
# MINIO_ROOT_PASSWORD=

# --- Local S3 Testing (cloud-dev profile) ---
# Start MinIO locally: docker compose --profile cloud-dev up
# MinIO Console: http://localhost:9001 (credentials from MINIO_ROOT_USER/PASSWORD above)
#
# To test S3 storage locally, uncomment and set:
# STORAGE_PROVIDER=s3
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=geolens
# S3_ACCESS_KEY_ID=<same value as MINIO_ROOT_USER>
# S3_SECRET_ACCESS_KEY=<same value as MINIO_ROOT_PASSWORD>
# S3_ALLOW_HTTP=true

# --- Azure Blob Storage (cloud-dev or production) ---
# [OPTIONAL] Required when STORAGE_PROVIDER=azure.
# Use either AZURE_STORAGE_CONNECTION_STRING (for Azurite or a full connection string)
# OR AZURE_STORAGE_ACCOUNT_URL + AZURE_STORAGE_ACCOUNT_KEY (for production key-auth).
# Managed identity / Entra ID auth: set AZURE_STORAGE_ACCOUNT_URL and leave
# AZURE_STORAGE_CONNECTION_STRING and AZURE_STORAGE_ACCOUNT_KEY unset.
#
# Type: string | No default
# AZURE_STORAGE_CONTAINER=geolens-prod
#
# Full connection string (Azurite dev or Azure Storage emulator):
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...
#
# Account URL for production (Entra ID / managed identity or key auth):
# AZURE_STORAGE_ACCOUNT_URL=https://<account>.blob.core.windows.net
#
# Storage account name used by GDAL/Titiler when no connection string is set.
# This is the <account> segment from AZURE_STORAGE_ACCOUNT_URL.
# AZURE_STORAGE_ACCOUNT=<account-name>
#
# Storage account access key (when using account_url + key auth, not connection_string):
# AZURE_STORAGE_ACCOUNT_KEY=<base64-encoded-key>

# [OPTIONAL] Threshold for multipart presigned S3 uploads in megabytes
# Files larger than this use multipart presigned URLs. Only applies when STORAGE_PROVIDER=s3.
# Type: integer (minimum 1) | Default: 100
# PRESIGNED_MULTIPART_THRESHOLD_MB=100

# --- Cache Provider ---
# [OPTIONAL] Redis/Valkey connection URL for cross-instance caching
# Leave unset to use in-memory caching (single-instance default).
# Type: string | No default
# Example: redis://redis:6379/0
# REDIS_URL=

# ==============================================================================
# ===== ADVANCED / PRODUCTION-TUNING BELOW =====
# ==============================================================================
# Everything below is opt-out from sensible defaults. New users almost never
# need to edit anything past this line; leave it alone unless you have a
# specific reason (CDN, cache tuning, custom pool sizing, rate-limit policy,
# managed-database SSL, load-test rigging).
#
# Two early-advanced sections appear ABOVE this divider for historical
# reasons (Uvicorn Tuning, Configuration Lockdown) — they're also opt-out.
# ==============================================================================

# --- CDN ---
# [OPTIONAL] CDN origin URL for tile delivery.
# NOTE: this is only a FALLBACK — the frontend's TILE_BASE_URL outranks it
# (resolveTileBaseUrl). Because docker-compose.prod.yml defaults the frontend
# TILE_BASE_URL to /api, setting CDN_BASE_URL alone does NOT reroute tiles; it
# only flips the admin "Tile Cache" badge to "CDN". To actually serve tiles from
# a separate CDN host, set FRONTEND_TILE_BASE_URL (frontend service). A CDN
# fronting the whole domain needs neither — tiles route through the edge same-origin.
# Type: string | No default
# Example: https://cdn.example.com/tiles
# CDN_BASE_URL=

# --- Tile Cache ---
# [OPTIONAL] Tile cache TTL in seconds
# Type: integer (minimum 0) | Default: 300
# TILE_CACHE_TTL=300

# [OPTIONAL] Secret for signing tile request URLs (prevents unauthorized tile access)
# Falls back to JWT_SECRET_KEY if not set.
# Type: string | Default: (uses JWT_SECRET_KEY)
# TILE_SIGNING_SECRET=

# [OPTIONAL] Internal Titiler origin used by the API raster proxy. Override for
# non-Compose deployments or a differently named raster service.
# Type: URL | Default: http://titiler:8000
# TITILER_BASE_URL=http://titiler:8000

# --- Worker ---
# [OPTIONAL] Graceful shutdown timeout for background worker in seconds
# Type: integer (minimum 1) | Default: 30
# WORKER_SHUTDOWN_TIMEOUT=30

# Number of jobs processed concurrently by one worker process.
# Type: integer (minimum 1) | Default: 1
# WORKER_CONCURRENCY=1

# Comma-separated Procrastinate queues consumed by this worker. Use a subset
# such as raster for a dedicated worker, but never an empty list.
# Type: comma-separated string | Default: priority,ingest,raster
# WORKER_QUEUES=priority,ingest,raster

# Retain completed/failed/cancelled/fanned-out ingest jobs for this many days.
# Zero keeps history forever.
# Type: integer (minimum 0) | Default: 30
# INGEST_JOBS_RETENTION_DAYS=30

# --- Frontend Dev-Server Proxy ---
# [OPTIONAL] Vite dev-server proxy target. Consumed only by frontend/vite.config.ts
# (Node side); NOT exposed to the browser bundle. The dev container sets this to
# http://api:8000 so the browser's /api/* requests forward to the FastAPI service.
# Outside Docker (host-side dev), the default `http://localhost:8000` works as long
# as you also run `uv run uvicorn ... --port 8000`.
# Type: string | Default: http://localhost:8000 (host-side) / http://api:8000 (compose)
# API_PROXY_TARGET=

# --- Tooling / Load Tests ---
# [OPTIONAL] Base URL consumed by load-test scripts (tests/load/common.py,
# tests/load/locustfile.py) and the seed script (scripts/seed-showcase.py).
# Distinct from PUBLIC_API_URL because tooling
# typically targets the *frontend* origin (so the Vite proxy or nginx routes
# /api/* to the backend) rather than the raw backend.
# Type: string | Default: http://localhost:8080
# GEOLENS_BASE_URL=

# [OPTIONAL] API key required by tests/load. Generate it from the GeoLens user
# settings/API-key screen; never commit a populated value.
# Type: secret string | No default
# GEOLENS_API_KEY=

# [OPTIONAL] Saved CLI instance URL and token. CLI login normally persists these
# in the user's config directory; env values are useful for ephemeral CI jobs.
# Type: URL | No default
# GEOLENS_INSTANCE=
# Type: secret string | No default
# GEOLENS_TOKEN=

# [DEPRECATED] Seed-script-only fallback alias for GEOLENS_BASE_URL.
# Type: URL | No default
# GEOLENS_URL=

# --- Managed Database ---
# Minimum versions for an externally managed database (CV-2):
#   - PostgreSQL >= 13   (gen_random_uuid() is used as a column default; core in PG13+)
#   - pgvector   >= 0.5  (HNSW index for semantic search; migration 0012 fails on older)
#   - Required extensions: postgis, pg_trgm, vector (pgvector), unaccent
# Migration 0001 RAISEs a clear error if the server is older than PostgreSQL 13.
#
# [OPTIONAL] Full PostgreSQL connection URL for managed databases (RDS, Cloud SQL)
# When set, overrides individual POSTGRES_* variables for the application connection.
# Type: PostgreSQL URL with one network or socket host and a database name | No default
# Example: postgresql://user:pass@rds-host:5432/geolens
# Unix socket: postgresql+asyncpg://user:pass@/geolens?host=/var/run/postgresql
#
# Least-privilege role recommendation
# The configured Postgres role SHOULD NOT be the cluster superuser. Using a
# least-privilege application role limits the blast radius of a backend
# compromise: the app does not need CREATEDB, CREATEROLE, BYPASSRLS, or
# REPLICATION. Below is a recipe to create a minimal geolens_app role.
#
# CREATE ROLE geolens_app LOGIN PASSWORD 'change-me-use-openssl-rand-hex-32';
# GRANT CONNECT ON DATABASE geolens TO geolens_app;
# GRANT USAGE ON SCHEMA catalog TO geolens_app;
# GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA catalog TO geolens_app;
# GRANT USAGE, SELECT ON ALL SEQUENCES IN SCHEMA catalog TO geolens_app;
# GRANT EXECUTE ON ALL FUNCTIONS IN SCHEMA catalog TO geolens_app;
# -- Apply to tables/sequences created by future migrations:
# ALTER DEFAULT PRIVILEGES IN SCHEMA catalog
#   GRANT SELECT, INSERT, UPDATE, DELETE ON TABLES TO geolens_app;
# ALTER DEFAULT PRIVILEGES IN SCHEMA catalog
#   GRANT USAGE, SELECT ON SEQUENCES TO geolens_app;
#
# Migration note: Alembic migrations run as the configured database user. If
# you use the locked-down geolens_app role above, migrations that CREATE or
# DROP tables will fail (the role lacks CREATE privilege on the schema). The
# recommended operator trade-off is to run Alembic using a separate migrator
# role that has CREATE privilege on the catalog schema, and switch back to
# geolens_app for the running application. Example:
#   DATABASE_URL_OVERRIDE=postgresql://geolens_migrator:...@host:5432/geolens
# (for migrations only, then reset to the geolens_app URL for the app service).
# DATABASE_URL_OVERRIDE=

# [OPTIONAL] Database SSL mode
# Type: string | Default: prefer | Options: disable, prefer, require, verify-full
# Note: verify-full requires DATABASE_SSL_CA_CERT to be set.
#
# Recommended values per deployment target:
#   - Local docker-compose dev (bundled postgres image): prefer
#       asyncpg attempts SSL and transparently falls back to plain TCP if the
#       postgres image isn't built with TLS. Empty-string was the BU-01 root
#       cause — set DATABASE_SSL_MODE=prefer, not "".
#   - Local non-docker dev (system postgres without TLS): disable
#   - Managed Postgres (RDS, Cloud SQL, etc.): require or verify-full
# DATABASE_SSL_MODE=prefer

# [OPTIONAL] Path to CA certificate file for database SSL verification
# Required when DATABASE_SSL_MODE=verify-full.
# Type: string | No default
# DATABASE_SSL_CA_CERT=

# [OPTIONAL] Enable connection pool pre-ping
# Detects broken connections before use. Adds slight latency per checkout.
# Recommended for managed databases. Set to false only if you need to disable.
# Type: boolean | Default: true
# DATABASE_POOL_PRE_PING=true

# --- External Connection Pooler ---
# [OPTIONAL] Enable external connection pooler mode (PgBouncer, RDS Proxy)
# Disables prepared statements across all database consumers (FastAPI, Procrastinate).
# Type: boolean | Default: false
# DB_USE_EXTERNAL_POOLER=false

# --- Connection Pool Tuning ---
# Ignored when DB_USE_EXTERNAL_POOLER=true.
# [OPTIONAL] Maximum persistent connections in the SQLAlchemy pool
# Type: integer (minimum 1) | Default: 10
# DB_POOL_SIZE=10

# [OPTIONAL] Maximum overflow connections beyond DB_POOL_SIZE.
# Default lowered from 5 to 3 to give max_connections=30 some room above the
# worst-case 30 in-flight. See
# README §"Connection Pool Budget" for the full arithmetic.
# Type: integer (minimum -1; -1 means unlimited) | Default: 3
# DB_MAX_OVERFLOW=3

# [OPTIONAL] Seconds to wait for a connection from the pool before raising
# Type: integer (minimum 1) | Default: 30
# DB_POOL_TIMEOUT=30

# [OPTIONAL] Seconds after which a connection is recycled (replaced)
# Prevents stale connections with managed databases.
# Type: integer (minimum -1; -1 disables recycling) | Default: 1800
# DB_POOL_RECYCLE=1800

# [OPTIONAL] Minimum connections in the dedicated asyncpg tile query pool
# Type: integer (minimum 1) | Default: 2
# TILE_POOL_MIN_SIZE=2

# [OPTIONAL] Maximum connections in the dedicated asyncpg tile query pool
# Type: integer (minimum 1; must be >= TILE_POOL_MIN_SIZE) | Default: 10
# TILE_POOL_MAX_SIZE=10

# Rate limits (Admin Settings only)
# Semantic-search and basemap-proxy limits are runtime PersistentConfig values,
# not environment variables. Configure them in Admin > Settings > Network or
# through PUT /settings/ using semantic_search_rate_limit and
# basemap_proxy_rate_limit. Defaults remain 30/min and 120/min respectively.

# ==============================================================================
# --- Prod-Image / Prebuilt Deploy (INST-03) ---
# ==============================================================================
# These four knobs select the PREBUILT-image deploy path (docker-compose.prod.yml)
# instead of building from source (docker-compose.yml). `bash scripts/install.sh`
# writes GEOLENS_VERSION + COMPOSE_FILE into .env automatically when it resolves a
# release; set them by hand only for a manual prebuilt deploy. REGISTRY/IMAGE_OWNER
# stay at their defaults unless you mirror the published images to your own GHCR/org.
#
# Manual prebuilt deploy (copy-paste):
#   1. Set the two lines below:
#        COMPOSE_FILE=docker-compose.prod.yml
#        GEOLENS_VERSION=X.Y.Z           # the published release tag (bare semver, no leading v)
#   2. Pull the version-pinned, published images:
#        docker compose pull
#   3. Boot:
#        docker compose up -d
#   (With COMPOSE_FILE set in .env, bare `docker compose` picks up the prod file;
#    omit it and pass `-f docker-compose.prod.yml` on every command instead.)

# [OPTIONAL] Published image tag to pull. Use bare semver, e.g. 1.2.3 — NOT v1.2.3:
# docker-compose.prod.yml uses this value verbatim as the GHCR image tag and published
# tags are bare semver, so a leading `v` makes `docker compose pull` request a
# non-existent `:v1.2.3`. (Only install.sh/upgrade.sh strip a leading `v`.) install.sh
# sets this to the resolved release tag. Unset → docker-compose.prod.yml defaults to `latest`.
# Type: string | No default (prod compose falls back to `latest`)
# GEOLENS_VERSION=

# [OPTIONAL] Which compose file bare `docker compose` uses. install.sh writes
# `docker-compose.prod.yml` for a release install, `docker-compose.yml` for source/dev.
# Type: string | Default: docker-compose.yml (bare compose auto-discovery)
# COMPOSE_FILE=docker-compose.prod.yml

# [OPTIONAL] Container registry hosting the published images. Override only if you
# mirror the images elsewhere.
# Type: string | Default: ghcr.io
# REGISTRY=ghcr.io

# [OPTIONAL] Org/owner namespace under the registry (the image path is
# ${REGISTRY}/${IMAGE_OWNER}/geolens-api etc.). Override only for a mirror/fork.
# Type: string | Default: geolens-io
# IMAGE_OWNER=geolens-io

# [OPTIONAL] Browser API base injected into the prebuilt frontend at container
# start. Keep /api for same-origin nginx proxying.
# Type: URL path or absolute URL | Default: /api
# FRONTEND_API_BASE_URL=/api

# [OPTIONAL] Browser tile base injected into the prebuilt frontend. Set a CDN
# origin only when tiles are actually routed there.
# Type: URL path or absolute URL | Default: /api
# FRONTEND_TILE_BASE_URL=/api
