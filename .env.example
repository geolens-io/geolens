# ==============================================================================
# GeoLens Environment Configuration
# Copy this file to .env. Works out of the box for local development.
# For production, change passwords and secrets marked with [CHANGE IN PRODUCTION].
# ==============================================================================

# --- Database ---
# PostgreSQL database name
# Type: string | Default: geolens
POSTGRES_DB=geolens

# PostgreSQL username
# Type: string | Default: geolens
POSTGRES_USER=geolens

# [CHANGE IN PRODUCTION] PostgreSQL password
# Type: string | Default: geolens (local dev)
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=geolens

# --- Authentication ---
# [REQUIRED] Secret key for signing JWT tokens (must be at least 32 chars)
# Type: string | No default — the application refuses to start until this is set
# Generate with: openssl rand -hex 32
# NOTE: known-public example values like "dev-only-change-me-in-production"
# are rejected at startup (Phase 268 H-28). Generate a real secret.
JWT_SECRET_KEY=

# JWT signing algorithm
# Type: string | Default: HS256
# JWT_ALGORITHM=HS256

# JWT access token lifetime in minutes
# Type: integer | Default: 15
# ACCESS_TOKEN_EXPIRE_MINUTES=15

# JWT refresh token lifetime in days
# Type: integer | Default: 7
# REFRESH_TOKEN_EXPIRE_DAYS=7

# [REQUIRED] Admin account username — created on first startup when no users exist
# Type: string | No default — the application refuses to start until this is set
# Pick any non-empty username (e.g., admin, ops, ishiland).
# NOTE: empty values fail boot per the same pattern as JWT_SECRET_KEY (Phase 273 SEC-15).
GEOLENS_ADMIN_USERNAME=

# [REQUIRED] Admin account password — created on first startup when no users exist
# Type: string | No default — the application refuses to start until this is set
# Min length: 8. Generate a strong one: openssl rand -base64 16
# NOTE: empty values fail boot per Phase 273 SEC-15.
GEOLENS_ADMIN_PASSWORD=

# Note: POSTGRES_HOST / POSTGRES_PORT are set automatically by docker-compose.yml
# (host=db, port=5432). When running the backend test suite outside Docker, copy
# .env.test.example to .env.test instead — see backend/tests/conftest.py for the
# variables required by the host-side test path (POSTGRES_HOST=localhost, etc.).

# Whether new user self-registration is enabled
# Type: boolean | Default: false
# REGISTRATION_ENABLED=false

# PostgreSQL schema name for the Procrastinate job queue tables
# Type: string | Default: catalog
# PROCRASTINATE_SCHEMA=catalog

# --- Public URLs ---
# [OPTIONAL] Browser-facing app URL (used for share links, OAuth redirects).
# Built-in default: http://localhost:8080 (matches _DEFAULT_PUBLIC_APP_URL in
# backend/app/core/public_urls.py).
# Type: string | Default: http://localhost:8080
# PUBLIC_APP_URL=http://localhost:8080

# [OPTIONAL] Externally-reachable API base URL (used in OGC self/collection/next
# link hrefs and similar self-referencing URL emissions). Built-in default:
# http://localhost:8000 (matches _DEFAULT_PUBLIC_API_URL in
# backend/app/core/public_urls.py). Containerized dev typically sets this to
# http://localhost:8080/api so the Vite dev-proxy rewrites it to the API
# container — see frontend/vite.config.ts.
# Type: string | Default: http://localhost:8000
# PUBLIC_API_URL=http://localhost:8000

# [DEPRECATED] Legacy alias for PUBLIC_API_URL. Use PUBLIC_API_URL instead.
# When set, the application logs a deprecation warning at startup (CONF-01,
# Phase 277). The variable still resolves to PUBLIC_API_URL for backwards
# compatibility but will be removed in a future release.
# Type: string | Default: none
# PUBLIC_BASE_URL=

# --- Logging ---
# Output logs in JSON format (recommended for production)
# Type: boolean | Default: false
# LOG_JSON=false

# Log level
# Type: string | Default: INFO | Options: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# --- Upload ---
# Maximum upload file size in megabytes
# Type: integer | Default: 500
# UPLOAD_MAX_SIZE_MB=500

# Staging directory for uploaded files
# Type: string | Default: /app/staging
# UPLOAD_STAGING_DIR=/app/staging

# Allowed file extensions for upload (comma-separated)
# Type: string | Default: .zip,.gpkg,.geojson,.json,.csv,.tif,.tiff,.xlsx,.xls
# UPLOAD_ALLOWED_EXTENSIONS=.zip,.gpkg,.geojson,.json,.csv,.tif,.tiff,.xlsx,.xls

# --- Uvicorn Tuning (Phase 272 / INF-08) ---
# Number of uvicorn worker processes. Dev compose default 1 (compatible with
# --reload). Production demo / single-VPS deploy: 2-4 depending on CPU.
# Multiplies request concurrency but also process memory (~150M baseline per worker).
# Type: integer | Default: 1
# UVICORN_WORKERS=1

# Keep-alive timeout in seconds — how long a connection stays open between requests.
# Default 5s matches uvicorn upstream; tune up for clients with chatty long-poll patterns.
# Type: integer | Default: 5
# UVICORN_TIMEOUT_KEEP_ALIVE=5

# Graceful-shutdown timeout in seconds — max time uvicorn waits for in-flight
# requests to finish before SIGKILL. 30s default covers slow GDAL ingest finalize.
# Type: integer | Default: 30
# UVICORN_TIMEOUT_GRACEFUL_SHUTDOWN=30

# --- Enterprise Extensions ---
# [OPTIONAL] Path to the geolens-enterprise package inside the container.
# Used by api-entrypoint.sh and worker-entrypoint.sh to auto-install enterprise
# extensions on startup. Set by the enterprise repo's compose overlay or
# deployment packaging.
# Type: string | Default: /enterprise
# GEOLENS_ENTERPRISE_PATH=/enterprise

# [OPTIONAL] Override the auto-detected edition. Without this, the edition is
# "enterprise" if any plugin extensions are loaded, otherwise "community".
# Type: string | Default: (auto-detected) | Options: community, enterprise
# GEOLENS_EDITION=

# --- Demo Overlay ---
# When running the public-demo overlay (docker-compose.demo.yml), additional
# variables come from .env.demo. The demo-only knob RESET_INTERVAL_HOURS controls
# how often the seeded demo data is wiped and reseeded. See .env.demo for details.

# --- Configuration Lockdown ---
# [OPTIONAL] When true, all admin-overridable settings are locked to their
# environment values. The PersistentConfig DB layer is bypassed for reads and
# returns 403 on writes. Use for hardened production deployments where operators
# must commit changes via env vars (and a re-deploy) instead of the admin UI.
# The admin Settings UI displays a banner indicating lockdown is active.
# Type: boolean | Default: false | Accepted: true, 1, yes
# ENV_ONLY_CONFIG=false

# --- Host Ports (development only) ---
# These are only used by docker-compose.yml for local development. They map host
# ports to the container ports — change them if 5434/8001/8080 are already taken.

# Host port for the Postgres container (container port is always 5432)
# Type: integer | Default: 5434
DB_PORT=5434

# Host port for the API container (container port is always 8000)
# Type: integer | Default: 8001
API_PORT=8001

# Host port for the frontend container (container port is always 5173)
# Type: integer | Default: 8080
FRONTEND_PORT=8080

# --- CORS ---
# [OPTIONAL] Comma-separated list of allowed origins for cross-origin API requests
# Leave empty for same-origin only (no CORS headers sent).
# Required when the frontend is served from a different domain than the API.
# Type: string (comma-separated URLs) | Default: "" (same-origin only)
# Example: https://app.example.com,https://other.example.com
# CORS_ALLOWED_ORIGINS=

# --- Backup Automation ---
# Cron schedule for automated database backups (cron expression)
# Default runs daily at 2:00 AM UTC
# Type: string (cron expression) | Default: 0 2 * * *
# BACKUP_SCHEDULE=0 2 * * *

# Number of daily backups to retain locally
# Type: integer | Default: 7
# BACKUP_RETENTION_DAILY=7

# Number of weekly (Sunday) backups to retain locally
# Type: integer | Default: 4
# BACKUP_RETENTION_WEEKLY=4

# Enable off-site backup upload to S3-compatible storage
# Uses the same S3_* credentials configured in Infrastructure Providers section.
# Type: boolean | Default: false
# BACKUP_S3_ENABLED=false

# ==============================================================================
# AI & Embeddings
# All settings below are optional. AI features are disabled when no API key is set.
# All AI settings can also be overridden from Admin > Settings > AI.
# ==============================================================================

# --- LLM Inference ---
# [OPTIONAL] Anthropic API key for Claude models
# Type: string | No default
# ANTHROPIC_API_KEY=

# [OPTIONAL] OpenAI API key (used for OpenAI-compatible providers)
# Type: string | No default
# OPENAI_API_KEY=

# [OPTIONAL] LLM model for Anthropic provider
# Type: string | Default: claude-sonnet-4-20250514
# LLM_MODEL=claude-sonnet-4-20250514

# [OPTIONAL] LLM model for OpenAI-compatible provider
# Type: string | Default: gpt-4o
# OPENAI_MODEL=gpt-4o

# [OPTIONAL] Custom base URL for OpenAI-compatible providers (Ollama, Groq, Together, etc.)
# Type: string | No default
# Example: http://host.docker.internal:11434/v1 (Ollama)
# OPENAI_BASE_URL=

# --- Semantic Search & Embeddings ---
# [OPTIONAL] Embedding model name (must be available at the embedding endpoint)
# Type: string | Default: text-embedding-3-small
# EMBEDDING_MODEL=text-embedding-3-small

# [OPTIONAL] Vector dimensions output by the embedding model
# Type: integer | Default: 1536
# EMBEDDING_DIMS=1536

# [OPTIONAL] Separate base URL for embedding generation
# Falls back to OPENAI_BASE_URL if empty.
# Type: string | No default
# EMBEDDING_BASE_URL=

# ==============================================================================
# Infrastructure Providers (v5.0 Cloud-Ready)
# All settings below are optional. Defaults work with Docker Compose.
# ==============================================================================

# --- Storage Provider ---
# [OPTIONAL] Storage backend for uploaded files
# Type: string | Default: local | Options: local, s3
# STORAGE_PROVIDER=local

# [OPTIONAL] S3-compatible endpoint URL (required when STORAGE_PROVIDER=s3)
# For AWS S3: leave unset (uses default). For MinIO: http://minio:9000
# Type: string | No default
# S3_ENDPOINT=

# [OPTIONAL] S3 bucket name (required when STORAGE_PROVIDER=s3)
# Type: string | No default
# S3_BUCKET=

# [OPTIONAL] S3 access key ID (required when STORAGE_PROVIDER=s3)
# Type: string | No default
# S3_ACCESS_KEY_ID=

# [OPTIONAL] S3 secret access key (required when STORAGE_PROVIDER=s3)
# Type: string | No default
# S3_SECRET_ACCESS_KEY=

# [OPTIONAL] S3 region
# Type: string | Default: us-east-1
# S3_REGION=us-east-1

# [OPTIONAL] Allow HTTP (non-TLS) connections to S3 endpoint (for local MinIO)
# Type: boolean | Default: false
# S3_ALLOW_HTTP=false

# [OPTIONAL] S3 addressing style: auto, path, or virtual
# Use 'path' for MinIO; 'virtual' for native AWS S3 in some regions; 'auto' lets the SDK decide.
# Type: string | Default: auto | Options: auto, path, virtual
# S3_ADDRESSING_STYLE=auto

# --- MinIO (cloud-dev profile only) ---
# Phase 1061 SEC-S07: REQUIRED if you run `docker compose --profile cloud-dev up`.
# No defaults — boot fails fast if these are unset (:-minioadmin defaults removed).
# Generate with openssl or scripts/init-demo-env.sh. Keep in sync with
# S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY below when using local MinIO.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# --- Local S3 Testing (cloud-dev profile) ---
# Start MinIO locally: docker compose --profile cloud-dev up
# MinIO Console: http://localhost:9001 (credentials from MINIO_ROOT_USER/PASSWORD above)
#
# To test S3 storage locally, uncomment and set:
# STORAGE_PROVIDER=s3
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=geolens
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_ALLOW_HTTP=true

# [OPTIONAL] Threshold for multipart presigned S3 uploads in megabytes
# Files larger than this use multipart presigned URLs. Only applies when STORAGE_PROVIDER=s3.
# Type: integer | Default: 100
# PRESIGNED_MULTIPART_THRESHOLD_MB=100

# --- Cache Provider ---
# [OPTIONAL] Redis/Valkey connection URL for cross-instance caching
# Leave unset to use in-memory caching (single-instance default).
# Type: string | No default
# Example: redis://redis:6379/0
# REDIS_URL=

# --- CDN ---
# [OPTIONAL] CDN origin URL for tile delivery
# When set, the frontend requests tiles from this URL instead of the API.
# Type: string | No default
# Example: https://cdn.example.com/tiles
# CDN_BASE_URL=

# --- Tile Cache ---
# [OPTIONAL] Tile cache TTL in seconds
# Type: integer | Default: 300
# TILE_CACHE_TTL=300

# [OPTIONAL] Secret for signing tile request URLs (prevents unauthorized tile access)
# Falls back to JWT_SECRET_KEY if not set.
# Type: string | Default: (uses JWT_SECRET_KEY)
# TILE_SIGNING_SECRET=

# --- Worker ---
# [OPTIONAL] Graceful shutdown timeout for background worker in seconds
# Type: integer | Default: 30
# WORKER_SHUTDOWN_TIMEOUT=30

# --- Frontend Dev-Server Proxy ---
# [OPTIONAL] Vite dev-server proxy target. Consumed only by frontend/vite.config.ts
# (Node side); NOT exposed to the browser bundle. The dev container sets this to
# http://api:8000 so the browser's /api/* requests forward to the FastAPI service.
# Outside Docker (host-side dev), the default `http://localhost:8000` works as long
# as you also run `uv run uvicorn ... --port 8000`.
# Type: string | Default: http://localhost:8000 (host-side) / http://api:8000 (compose)
# API_PROXY_TARGET=

# --- Tooling / Load Tests ---
# [OPTIONAL] Base URL consumed by load-test scripts (tests/load/common.py,
# tests/load/locustfile.py) and seed scripts (scripts/seed-natural-earth.py,
# scripts/seed-perf-data.py, scripts/seed-ago-data.py, scripts/seed-e2e.py,
# scripts/demo/lib/create_api_key.py, examples/sdk/python/*). Distinct from
# PUBLIC_API_URL because tooling typically targets the *frontend* origin
# (so the Vite proxy or nginx routes /api/* to the backend) rather than the
# raw backend. The docker-compose.demo.yml overlay sets this to http://api:8000
# so seeders running inside the docker network bypass the proxy.
# Type: string | Default: http://localhost:8080 (host-side) / http://api:8000 (demo overlay)
# GEOLENS_BASE_URL=

# --- Managed Database ---
# [OPTIONAL] Full PostgreSQL connection URL for managed databases (RDS, Cloud SQL)
# When set, overrides individual POSTGRES_* variables for the application connection.
# Type: string | No default
# Example: postgresql://user:pass@rds-host:5432/geolens
# DATABASE_URL_OVERRIDE=

# [OPTIONAL] Database SSL mode
# Type: string | Default: prefer | Options: disable, prefer, require, verify-full
# Note: verify-full requires DATABASE_SSL_CA_CERT to be set.
#
# Recommended values per deployment target:
#   - Local docker-compose dev (bundled postgres image): prefer
#       asyncpg attempts SSL and transparently falls back to plain TCP if the
#       postgres image isn't built with TLS. Empty-string was the BU-01 root
#       cause — set DATABASE_SSL_MODE=prefer, not "".
#   - Local non-docker dev (system postgres without TLS): disable
#   - Managed Postgres (RDS, Cloud SQL, etc.): require or verify-full
# DATABASE_SSL_MODE=prefer

# [OPTIONAL] Path to CA certificate file for database SSL verification
# Required when DATABASE_SSL_MODE=verify-full.
# Type: string | No default
# DATABASE_SSL_CA_CERT=

# [OPTIONAL] Enable connection pool pre-ping
# Detects broken connections before use. Adds slight latency per checkout.
# Recommended for managed databases. Set to false only if you need to disable.
# Type: boolean | Default: true
# DATABASE_POOL_PRE_PING=true

# --- External Connection Pooler ---
# [OPTIONAL] Enable external connection pooler mode (PgBouncer, RDS Proxy)
# Disables prepared statements across all database consumers (FastAPI, Procrastinate).
# Type: boolean | Default: false
# DB_USE_EXTERNAL_POOLER=false

# --- Connection Pool Tuning ---
# Ignored when DB_USE_EXTERNAL_POOLER=true.
# [OPTIONAL] Maximum persistent connections in the SQLAlchemy pool
# Type: integer | Default: 10
# DB_POOL_SIZE=10

# [OPTIONAL] Maximum overflow connections beyond DB_POOL_SIZE.
# DBM-04 (Phase 271): default lowered from 5 to 3 to give max_connections=30
# (PERF-05 / Phase 274) some room above the worst-case 30 in-flight. See
# README §"Connection Pool Budget" for the full arithmetic.
# Type: integer | Default: 3
# DB_MAX_OVERFLOW=3

# [OPTIONAL] Seconds to wait for a connection from the pool before raising
# Type: integer | Default: 30
# DB_POOL_TIMEOUT=30

# [OPTIONAL] Seconds after which a connection is recycled (replaced)
# Prevents stale connections with managed databases.
# Type: integer | Default: 1800
# DB_POOL_RECYCLE=1800

# [OPTIONAL] Minimum connections in the dedicated asyncpg tile query pool
# Type: integer | Default: 2
# TILE_POOL_MIN_SIZE=2

# [OPTIONAL] Maximum connections in the dedicated asyncpg tile query pool
# Type: integer | Default: 10
# TILE_POOL_MAX_SIZE=10

# --- Rate limits (per-IP, slowapi) ---
# [OPTIONAL] Per-IP request limit (per minute) for /search/datasets/ and /datasets/{id}/related/
# Caps OpenAI embedding cost-DoS: each unique query string triggers an embeddings API call.
# SEC-S11: audit recommendation is 30/min for cost-sensitive endpoints.
# Type: integer | Default: 30
# SEMANTIC_SEARCH_RATE_LIMIT=30

# [OPTIONAL] Per-IP request limit (per minute) for /settings/basemaps/
# Caps replay of commercial-tier basemap keys (Mapbox/Stadia/MapTiler) from anonymous clients.
# 120/min is loose enough for the SPA boot path across users behind a shared NAT.
# Do NOT put a backend-only commercial-tier key in basemap config — use client-side tile-provider keys.
# SEC-S10: rate limiting is a defense-in-depth layer; key rotation is the primary mitigation.
# Type: integer | Default: 120
# BASEMAP_PROXY_RATE_LIMIT=120
