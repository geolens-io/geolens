{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.geolens.io/geolens-manifest/v1/schema.json",
  "title": "GeoLens Manifest v1",
  "description": "Versioned geolens.yaml catalog manifest contract.",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "catalog", "datasets"],
  "properties": {
    "manifest_version": {
      "type": "string",
      "const": "1",
      "description": "Manifest schema version. GeoLens v13.7 supports version 1."
    },
    "catalog": {
      "$ref": "#/$defs/catalog"
    },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/dataset"
      }
    }
  },
  "$defs": {
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Human-readable catalog title."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 5000,
          "description": "Human-readable catalog description."
        },
        "organization": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Organization responsible for the catalog."
        },
        "contact": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            },
            "email": {
              "type": "string",
              "format": "email",
              "maxLength": 320
            },
            "url": {
              "type": "string",
              "pattern": "^https?://[^\\s]+$",
              "maxLength": 2000
            }
          }
        }
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "title", "sources", "publication"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$",
          "description": "Stable dataset identity key used for idempotent apply operations."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "Human-readable dataset title."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 5000,
          "description": "Human-readable dataset description."
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source"
          }
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        },
        "publication": {
          "$ref": "#/$defs/publication"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "uri"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["vector", "raster_cog", "vrt"],
          "description": "Source modality."
        },
        "uri": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000,
          "pattern": "^(?:(?:\\.{1,2}/)?[^\\s:/][^\\s]*|https?://[^\\s]+|s3://[^\\s]+|gs://[^\\s]+|az://[^\\s]+|abfs://[^\\s]+)$",
          "description": "Relative path, HTTP(S) URL, or storage URI."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 5000
        },
        "format": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "layer": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "uniqueItems": true
        },
        "organization": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "crs": {
          "type": "string",
          "pattern": "^EPSG:[0-9]{1,6}$"
        },
        "license": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "attribution": {
          "type": "string",
          "minLength": 1,
          "maxLength": 5000
        },
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "number",
            "minimum": -180,
            "maximum": 180
          },
          "description": "WGS84 bbox hint: [minx, miny, maxx, maxy]."
        }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intent"],
      "properties": {
        "intent": {
          "type": "string",
          "enum": ["draft", "ready", "internal", "published"],
          "description": "Community-safe publication intent."
        }
      }
    }
  }
}
