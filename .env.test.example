# ==============================================================================
# GeoLens Test Environment Configuration
# ==============================================================================
#
# This file documents the minimum environment variables required to run the
# backend test suite locally.
#
# USAGE:
#   1. Copy this file to .env.test:          cp .env.test.example .env.test
#   2. Export the vars into your shell:      set -a && source .env.test && set +a
#   3. Run the tests from backend/:          cd backend && uv run pytest
#
# OR, run a one-off test without sourcing:
#   env $(grep -v '^#' .env.test | xargs) uv run pytest tests/test_auth.py
#
# See backend/tests/conftest.py for how these values are consumed. The
# `_test_db_lifecycle` session fixture will:
#   - Connect to the primary Postgres instance using the values below
#   - CREATE a fresh database named POSTGRES_DB_TEST
#   - Apply alembic migrations against it
#   - DROP the test database at the end of the session
#
# The primary database (POSTGRES_DB) is only used briefly for CREATE/DROP
# DATABASE statements; no test data is written to it.
# ==============================================================================

# --- Database connection (target: the running Postgres on POSTGRES_HOST) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=geolens
POSTGRES_PASSWORD=geolens
POSTGRES_DB=geolens

# --- Test database name base ---
# conftest.py reads settings.postgres_db_test, then appends a short per-session
# suffix so concurrent pytest runs do not drop each other's databases.
# Override this base only when you need a different naming prefix.
# POSTGRES_DB_TEST=geolens_test

# --- Required for Settings() construction ---
# Must be ≥ 32 chars to satisfy the Settings validator (backend/app/config.py).
JWT_SECRET_KEY=test-secret-key-for-ci-padding-32chars
GEOLENS_ADMIN_USERNAME=admin
GEOLENS_ADMIN_PASSWORD=admin

# --- Optional: tests that exercise storage ---
# By default, tests point UPLOAD_STAGING_DIR at a per-test tmp_path.
# Uncomment to override globally.
# UPLOAD_STAGING_DIR=/tmp/geolens-test-staging

# --- Optional: silence logs during tests ---
# LOG_LEVEL=WARNING

# --- Optional: pytest-asyncio compatibility ---
# conftest.py forces AnyIO (asyncio backend), so you typically do NOT need to
# set PYTEST_ADDOPTS. Tests exclude the `perf` marker by default via
# addopts = "-m 'not perf'" in backend/pyproject.toml.
