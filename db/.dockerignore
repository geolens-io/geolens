# db/.dockerignore — patterns aligned with project convention (frontend/.dockerignore, root .dockerignore).
# Build context is small (Dockerfile + postgresql.conf), but defensive ignores
# prevent host .env files / OS junk / VCS metadata from accidentally landing in
# the image if someone drops them in db/.

.git
.git*
.env
.env.*
*.md
.DS_Store

# secrets / TLS material (D05, docker-audit-20260604) — defensive symmetry;
# db/Dockerfile has no COPY of its context, so near-zero real blast radius.
*.pem
*.key
*.crt
*.p12
*.pfx
